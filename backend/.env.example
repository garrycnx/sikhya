# ─── LOCAL DEVELOPMENT ──────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

NODE_ENV=development
PORT=3000

# ─── DATABASE ────────────────────────────────────────────────────────────────
# LOCAL: use individual vars
DB_HOST=localhost
DB_PORT=5433
DB_NAME=school_mgmt
DB_USER=school_admin
DB_PASSWORD=localdev_password_change_in_prod
DB_POOL_MIN=2
DB_POOL_MAX=10

# PRODUCTION (Railway): set DATABASE_URL instead of the vars above
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# App user (limited privileges, used for all queries via RLS)
DB_APP_USER=app_user
DB_APP_PASSWORD=app_user_pass_change_me

# ─── REDIS ────────────────────────────────────────────────────────────────────
# LOCAL: use individual vars
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=localdev_redis_pass

# PRODUCTION (Upstash): set REDIS_URL instead of the vars above
# REDIS_URL=rediss://default:your_password@your-host.upstash.io:6380

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_min_64_chars
JWT_REFRESH_SECRET=CHANGE_ME_min_64_chars_different_from_access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# PRODUCTION: comma-separated list of allowed frontend origins
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6
OTP_RATE_LIMIT_MAX=50

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── SMS (Fast2SMS) ───────────────────────────────────────────────────────────
# Leave blank in dev — OTP prints to console instead
# Get API key from https://www.fast2sms.com → Dev API → API Key
FAST2SMS_API_KEY=
